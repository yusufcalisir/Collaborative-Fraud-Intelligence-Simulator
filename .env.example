# ──────────────────────────────────────────────
# Collaborative Fraud Intelligence Simulator
# Environment Configuration
# ──────────────────────────────────────────────

# Application
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fraud_intelligence
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Celery Flower
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:change_me

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# FL Simulation Defaults
FL_DEFAULT_ROUNDS=10
FL_DEFAULT_LOCAL_EPOCHS=3
FL_DEFAULT_LEARNING_RATE=0.001
FL_DEFAULT_BATCH_SIZE=64
FL_MIN_CLIENTS_PER_ROUND=2
